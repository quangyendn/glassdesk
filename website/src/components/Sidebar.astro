---
import { getCollection } from "astro:content";

const all = await getCollection("wiki");

type Item = { slug: string; title: string };
const groups = new Map<string, Item[]>();

for (const e of all) {
  const slug = e.id.replace(/\.md$/, "");
  const parts = slug.split("/");
  const top = parts.length > 1 ? (parts[0] ?? "_root") : "_root";
  if (!groups.has(top)) groups.set(top, []);
  groups.get(top)!.push({ slug, title: e.data.title });
}

for (const arr of groups.values()) {
  arr.sort((a, b) => a.title.localeCompare(b.title));
}

const folderOrder = [
  "architecture",
  "features",
  "decisions",
  "risks",
  "insights",
  "manual",
  "_root",
];

const sortedGroups = [...groups.entries()].sort(([a], [b]) => {
  const ia = folderOrder.indexOf(a);
  const ib = folderOrder.indexOf(b);
  return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
});

const folderLabel = (f: string) => (f === "_root" ? "Overview" : f);

const { current } = Astro.props as { current?: string };
---

<aside class="doc-sidebar" aria-label="Sidebar">
  {
    sortedGroups.map(([folder, items]) => (
      <div class="doc-sidebar__group-block">
        <p class="doc-sidebar__group" id={`grp-${folder}`}>
          {folderLabel(folder)}
        </p>
        <ul role="list" aria-labelledby={`grp-${folder}`}>
          {items.map((i) => (
            <li>
              <a
                class:list={["doc-sidebar__link", { "is-active": current === i.slug }]}
                href={`/docs/${i.slug}`}
                aria-current={current === i.slug ? "page" : undefined}
              >
                {i.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</aside>

<style>
  .doc-sidebar {
    background: var(--bg-card);
    padding: 20px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    position: sticky;
    top: 88px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
  }

  .doc-sidebar__group-block {
    margin-bottom: 20px;
  }

  .doc-sidebar__group {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin: 0 0 8px;
    padding: 0;
  }

  .doc-sidebar__group-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .doc-sidebar__link {
    display: block;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 5px 8px;
    border-radius: 6px;
    border-left: 2px solid transparent;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .doc-sidebar__link:hover {
    color: var(--text-primary);
    text-decoration: none;
  }

  .doc-sidebar__link.is-active {
    color: var(--accent-neon);
    border-left-color: var(--accent-neon);
    background: color-mix(in srgb, var(--accent-neon) 6%, transparent);
  }
</style>