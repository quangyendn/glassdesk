---
// Lazy-loaded Pagefind search modal.
---

<button id="search-open" class="search-trigger" aria-label="Open search">
  Search
</button>
<dialog id="search-dialog" aria-label="Search">
  <div id="pagefind-ui"></div>
  <button id="search-close" class="close" aria-label="Close search">
    Close
  </button>
</dialog>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script>
  const open = document.getElementById("search-open");
  const dlg = document.getElementById("search-dialog") as HTMLDialogElement | null;
  const close = document.getElementById("search-close");
  let initialised = false;

  open?.addEventListener("click", async () => {
    if (!dlg) return;
    if (!initialised) {
      try {
        const mod = (await import(
          /* @vite-ignore */ "/pagefind/pagefind-ui.js"
        )) as { PagefindUI: new (opts: Record<string, unknown>) => unknown };
        new mod.PagefindUI({ element: "#pagefind-ui", showImages: false });
        initialised = true;
      } catch (err) {
        console.error("Pagefind UI failed to load:", err);
      }
    }
    dlg.showModal();
  });
  close?.addEventListener("click", () => dlg?.close());
</script>
