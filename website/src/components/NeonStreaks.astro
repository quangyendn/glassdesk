---
/**
 * NeonStreaks — absolute-positioned blurred accent streaks for the hero section.
 * aria-hidden: purely decorative, pointer-events: none via CSS.
 */
---

<div class="neon-streaks" aria-hidden="true">
  <span class="streak streak--1"></span>
  <span class="streak streak--2"></span>
  <span class="streak streak--3"></span>
  <span class="streak streak--4"></span>
  <span class="streak-glow"></span>
</div>
