---
/**
 * Icon — server-rendered SVG via lucide-static.
 *
 * name: lucide icon key in PascalCase (e.g. "Search", "BookOpen").
 *   Special value "github" maps to the GitHub mark (not in lucide-static).
 * size: px dimension applied via wrapper style (default 16).
 * color: CSS color string (default "currentColor").
 * class: extra class forwarded to wrapper <span>.
 * aria-label: if provided, renders aria-label on wrapper and aria-hidden on SVG.
 */
import * as icons from "lucide-static";

interface Props {
  name: string;
  size?: number;
  color?: string;
  class?: string;
  "aria-label"?: string;
}

const {
  name,
  size = 16,
  color = "currentColor",
  class: extraClass,
  "aria-label": ariaLabel,
} = Astro.props;

// The GitHub Invertocat mark — not in lucide-static.
const GITHUB_SVG = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`;

// Convert kebab-case name to PascalCase for lucide-static lookup.
function toPascalCase(str: string): string {
  return str
    .split("-")
    .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
    .join("");
}

let svg: string;
if (name === "github") {
  svg = GITHUB_SVG;
} else {
  const key = toPascalCase(name);
  svg = (icons as Record<string, string>)[key];
  if (!svg) {
    // Fallback: render a blank transparent box so layout doesn't break.
    svg = `<!-- icon ${name} not found --><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"></svg>`;
  }
}

const wrapperClass = ["icon", extraClass].filter(Boolean).join(" ");
---

<span
  class={wrapperClass}
  style={`width:${size}px;height:${size}px;color:${color};`}
  set:html={svg}
  {...ariaLabel ? { "aria-label": ariaLabel, role: "img" } : { "aria-hidden": "true" }}
/>
