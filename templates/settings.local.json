{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/session-init.cjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/dev-rules-reminder.cjs\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "env": {}
}
